PORT=3100
NODE_ENV=development

# Supabase/PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=conjunto_ong
DB_SSL=false

# Tambien puedes usar DATABASE_URL en lugar de DB_HOST/DB_USER/etc.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conjunto_ong

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h

ADMIN_USER=admin
ADMIN_PASSWORD=admin123
GESTOR_USER=gestor
GESTOR_PASSWORD=admin123

# Si la base no esta disponible, responde con datos demo en vez de 500.
DEMO_FALLBACK=true
